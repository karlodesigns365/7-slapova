{ "type": "Feature", "properties": { "id": 16, "naziv": "slap", "opis": "Jedan od najviših slapova na stazi, posebno impresivan nakon kiše kada ima više vode. Pristup zahtijeva oprez zbog strmog i skliskog terena.", "ime": "Grjok" }, "geometry": { "type": "Point", "coordinates": [ 13.9960292621909, 45.379660425341548 ] } },
{ "type": "Feature", "properties": { "id": 17, "naziv": "slap", "opis": "Manji, ali vrlo slikovit slap okružen zelenilom. Idealan za kratku pauzu na početku staze. Pristup je lagan, ali može biti sklizak nakon kiše.", "ime": "Zagon" }, "geometry": { "type": "Point", "coordinates": [ 13.990435150565904, 45.393742463774238 ] } },
{ "type": "Feature", "properties": { "id": 18, "naziv": "slap", "opis": "Jedan od atraktivnijih dijelova staze s većom količinom vode i impresivnim stijenama. Dobar za fotografiranje. Teren može biti zahtjevniji i sklizak.", "ime": "Mala peć" }, "geometry": { "type": "Point", "coordinates": [ 14.000487715965168, 45.3916212033308 ] } },
{ "type": "Feature", "properties": { "id": 19, "naziv": "slap", "opis": "Manje poznat slap, ali vrlo autentičan i divlji. Okružen gustom vegetacijom, pruža osjećaj netaknute prirode. Nije uvijek lako uočljiv.", "ime": "Zelenščak" }, "geometry": { "type": "Point", "coordinates": [ 13.999362777594911, 45.376725137573608 ] } },
{ "type": "Feature", "properties": { "id": 20, "naziv": "slap", "opis": "Najpoznatija i najatraktivnija lokacija na stazi. Prirodni kameni bazeni i slapovi stvaraju jedinstven krajolik. Odlično mjesto za odmor, fotografiranje i uživanje u prirodi.", "ime": "Kotli" }, "geometry": { "type": "Point", "coordinates": [ 14.016641795751315, 45.368652972315481 ] } },
{ "type": "Feature", "properties": { "id": 21, "naziv": "slap", "opis": "Slap prepoznatljiv po zanimljivim kamenim formacijama koje podsjećaju na bačvu. Okolina je mirna i pogodna za odmor. Prilaz je relativno jednostavan.", "ime": "Bačva" }, "geometry": { "type": "Point", "coordinates": [ 13.992625445152905, 45.393212328124108 ] } },
